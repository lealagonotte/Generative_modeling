{
    "output_folder": "./results",
    "n_replicates": 3,
    "metrics": ["wd", "swd", "cd"],
    "datasets":{
        "type": "compressed_sensing",
        "mode": "Nx2D",
        "m": [0.1, 0.33, 0.5, 0.66, 0.8],
        "m_prime": [1],
        "X_params":{
            "two_moons":{
                "n_clouds": 1000,
                "n_points_per_cloud": 300,
                "noise_min": 0.01,
                "noise_max": 0.35,
                "augment_rotation": 1,
                "augment_translation": 1,
                "augment_scale": 1
            },
            "swiss_roll":{
                "n_clouds": 1000,
                "n_points_per_cloud": 300,
                "noise_min": 0.1,
                "noise_max": 0.9,
                "augment_rotation": 1,
                "augment_translation": 1,
                "augment_scale": 1
            }
        }
    },
    "training":{
        "batch_size": 32,
        "schedule": "ve",
        "schedule_kwargs": {
            "sigma_min": 0.01,
            "sigma_max": 1.0
        },
        "module_kwargs":{
            "model": "flat_nx2d",
            "data_dim": 2,
            "n_layers": 3,
            "hidden_dim": 256
        },
        "epochs": 1000,
        "patience": 50,
        "adam_kwargs": {
            "lr": 1e-3
        },
        "sampler": "fms",
        "n_samples": 9,
        "n_steps": 1000
    },
    "viz":{
        "n_samples": 9,
        "n_steps": 1000
    }
}